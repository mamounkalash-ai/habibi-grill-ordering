# Square
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=REPLACE_WITH_SQUARE_APPLICATION_ID
SQUARE_LOCATION_ID=REPLACE_WITH_SQUARE_LOCATION_ID
SQUARE_ACCESS_TOKEN=REPLACE_WITH_SQUARE_ACCESS_TOKEN

# Square webhook (create this endpoint in Square Developer Dashboard)
SQUARE_WEBHOOK_NOTIFICATION_URL=https://YOUR-DOMAIN.com/api/square-webhook
SQUARE_WEBHOOK_SIGNATURE_KEY=REPLACE_WITH_WEBHOOK_SIGNATURE_KEY

# SMS provider. Use "twilio" or "webhook".
SMS_PROVIDER=twilio
SMS_FROM_NUMBER=+15314447691
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN

# Generic SMS bridge alternative
# SMS_PROVIDER=webhook
# SMS_WEBHOOK_URL=https://your-sms-provider.example/send
# SMS_WEBHOOK_TOKEN=optional-secret

# Optional: Upstash/Vercel KV prevents duplicate webhook texts
KV_REST_API_URL=
KV_REST_API_TOKEN=
